# PRITHVINET Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=PRITHVINET
ENVIRONMENT=development
DEBUG=True

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=prithvinet_secure_2024
CLICKHOUSE_DB=prithvinet

# PostgreSQL/PostGIS
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=prithvinet_secure_2024
POSTGRES_DB=prithvinet_geo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# External APIs
CPCB_API_URL=https://app.cpcbccr.com/ccr_docs/AQI_Bulletin.json
OPENAQ_API_URL=https://api.openaq.org/v2
INDIA_WRIS_URL=https://indiawris.gov.in

# ML Models
TIMESFM_ENABLED=True
NIXTLA_API_KEY=

# Data.gov.in API (for CGWB data)
DATA_GOV_API_KEY=
